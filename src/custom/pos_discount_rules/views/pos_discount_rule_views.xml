<odoo>
    <data>
    <!-- Vista Lista -->
    <record id="view_pos_discount_rule_tree" model="ir.ui.view">
        <field name="name">pos.discount.rule.tree</field>
        <field name="model">pos.discount.rule</field>
        <field name="arch" type="xml">
            <tree string="Reglas de Descuento por Horario">
                <field name="name"/>
                <field name="hour_from" widget="float_time"/>
                <field name="hour_to" widget="float_time"/>
                <field name="discount_percentage"/>
            </tree>
        </field>
    </record>

    <!-- Vista Formulario -->
    <record id="view_pos_discount_rule_form" model="ir.ui.view">
        <field name="name">pos.discount.rule.form</field>
        <field name="model">pos.discount.rule</field>
        <field name="arch" type="xml">
            <form string="Regla de Descuento por Horario">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="discount_percentage"/>
                        </group>
                        <group>
                            <field name="hour_from" widget="float_time"/>
                            <field name="hour_to" widget="float_time"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->

    <record id="action_pos_discount_rule" model="ir.actions.act_window">
        <field name="name">Reglas de Descuento por Horario</field>
        <field name="res_model">pos.discount.rule</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Create a new discount rule
          </p>
        </field>
    </record>

    <!-- Menú dentro de Punto de Venta -> Configuración -->
        <menuitem
        id="menu_pos_discount_rule"
        name="Descuentos por Horario"
        parent="point_of_sale.menu_point_config_product"
        action="action_pos_discount_rule"
        sequence="90"
    />
    </data>
</odoo>