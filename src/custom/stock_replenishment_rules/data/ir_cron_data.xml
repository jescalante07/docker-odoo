<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron job para verificación automática de reabastecimiento -->
        <record id="ir_cron_stock_replenishment_check" model="ir.cron">
            <field name="name">Verificación de Reabastecimiento por Prioridad</field>
            <field name="model_id" ref="model_stock_replenishment_rule"/>
            <field name="state">code</field>
            <field name="code">model.run_replenishment_check()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">10</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>
