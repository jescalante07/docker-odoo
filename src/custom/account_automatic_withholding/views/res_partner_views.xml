<odoo>

    <!-- ============================================================ -->
    <!-- Herencia Vista Formulario de Contacto                        -->
    <!-- ============================================================ -->
    <record id="res_partner_form_view_retention" model="ir.ui.view">
        <field name="name">res.partner.form.retention</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Stat button de retenciones -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_retentions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-percent"
                        groups="account.group_account_user"
                        invisible="retention_count == 0">
                    <field name="retention_count"
                           widget="statinfo"
                           string="Retenciones"/>
                </button>
            </xpath>

            <!-- Campo perfil fiscal junto a otros campos fiscales -->
            <xpath expr="//field[@name='property_account_position_id']" position="before">
                <field name="fiscal_profile"
                       groups="account.group_account_user"/>
            </xpath>

            <!-- Pestaña completa de configuración fiscal -->
            <xpath expr="//page[@name='sales_purchases']" position="after">
                <page string="Perfil Fiscal" name="fiscal_profile_page"
                      groups="account.group_account_user">
                    <group>
                        <group string="Clasificación Fiscal">
                            <field name="fiscal_profile"/>
                            <field name="fiscal_profile_note"
                                   placeholder="Observaciones adicionales sobre el tratamiento fiscal..."/>
                        </group>
                        <group string="Reglas de Retención Específicas">
                            <field name="retention_rule_ids"
                                   widget="many2many_tags"
                                   nolabel="1"
                                   colspan="2"
                                   placeholder="Reglas específicas para este contacto (opcional)..."
                                   help="Si define reglas aquí, tendrán prioridad sobre las del perfil fiscal."/>
                        </group>
                    </group>

                    <!-- Tabla informativa de retenciones del partner -->
                    <group string="Últimas Retenciones">
                        <field name="retention_count" readonly="1" string="Total de Retenciones"/>
                    </group>

                    <div class="alert alert-warning mb-3" role="alert"
                         invisible="fiscal_profile != 'exempt'">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <strong>Perfil Exento:</strong>
                        No se generarán retenciones automáticas en las facturas de este contacto.
                    </div>

                    <div class="alert alert-info mb-3" role="alert"
                         invisible="fiscal_profile != 'retention_agent'">
                        <i class="fa fa-info-circle me-2"/>
                        <strong>Agente de Retención:</strong>
                        Se aplicarán retenciones especiales en las facturas de este contacto.
                        Verifique que existan reglas configuradas para el perfil
                        <em>Agente de Retención</em>.
                    </div>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Herencia Vista Lista de Contactos                            -->
    <!-- ============================================================ -->
    <record id="res_partner_list_view_retention" model="ir.ui.view">
        <field name="name">res.partner.list.retention</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='phone']" position="after">
                <field name="fiscal_profile"
                       optional="show"
                       widget="badge"
                       decoration-info="fiscal_profile == 'standard'"
                       decoration-warning="fiscal_profile == 'retention_agent'"
                       decoration-success="fiscal_profile == 'simplified'"
                       decoration-danger="fiscal_profile == 'exempt'"
                       groups="account.group_account_user"/>
            </xpath>
        </field>
    </record>

</odoo>
