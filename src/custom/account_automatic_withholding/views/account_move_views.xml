<odoo>

    <!-- ============================================================ -->
    <!-- Herencia Vista Formulario de Factura                         -->
    <!-- ============================================================ -->
    <record id="account_move_form_view_retention" model="ir.ui.view">
        <field name="name">account.move.form.retention</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Stat button de retenciones -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_retentions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-percent"
                        invisible="retention_count == 0">
                    <field name="retention_count"
                           widget="statinfo"
                           string="Retenciones"/>
                </button>
            </xpath>

            <!-- Botón manual para aplicar retención post-confirmación -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_apply_retention_manual"
                        type="object"
                        string="Aplicar Retención"
                        class="oe_stat_button"
                        icon="fa-percent"
                        invisible="state != 'posted' or retention_count != 0 or move_type not in ['out_invoice','out_refund','in_invoice','in_refund']"
                        groups="account.group_account_manager"/>
            </xpath>

            <!-- Bloque de retenciones en el pie de la factura -->
            <xpath expr="//group[@class='oe_subtotal_footer']" position="after">
                <div class="o_invoice_retention_info mt-2"
                     invisible="retention_count == 0">
                    <div class="alert alert-secondary py-2 px-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>
                                <i class="fa fa-percent me-1"/>
                                <strong>Total Retenido:</strong>
                            </span>
                            <span class="fw-bold text-danger">
                                <field name="total_retention_amount"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       readonly="1"/>
                            </span>
                        </div>
                    </div>
                </div>
            </xpath>

            <!-- Opción para omitir retención automática -->
            <xpath expr="//page[@id='other_tab']" position="inside">
                <group string="Retenciones" groups="account.group_account_manager">
                    <field name="skip_auto_retention"
                           widget="boolean_toggle"
                           readonly="state != 'draft'"/>
                    <field name="has_retention" readonly="1" widget="boolean_toggle"/>
                    <field name="total_retention_amount"
                           readonly="1"
                           invisible="not has_retention"/>
                    <field name="currency_id" invisible="1"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
