<odoo>
    <data noupdate="1">

        <!-- Secuencia para comprobantes de retención -->
        <record id="sequence_account_retention" model="ir.sequence">
            <field name="name">Retención Fiscal</field>
            <field name="code">account.retention</field>
            <field name="prefix">RET/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
