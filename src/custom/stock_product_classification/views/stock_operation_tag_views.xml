<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         VISTAS: stock.operation.tag
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Vista Lista -->
    <record id="view_stock_operation_tag_list" model="ir.ui.view">
        <field name="name">stock.operation.tag.tree</field>
        <field name="model">stock.operation.tag</field>
        <field name="arch" type="xml">
            <tree string="Etiquetas Operativas"
                  decoration-muted="not active"
                  editable="bottom">
                <field name="color" widget="color_picker" optional="show"/>
                <field name="name"/>
                <field name="operation_type"/>
                <field name="description" optional="hide"/>
                <field name="product_count" string="Productos"/>
                <field name="active" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Vista Formulario -->
    <record id="view_stock_operation_tag_form" model="ir.ui.view">
        <field name="name">stock.operation.tag.form</field>
        <field name="model">stock.operation.tag</field>
        <field name="arch" type="xml">
            <form string="Etiqueta Operativa">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_products"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-cube"
                                invisible="product_count == 0">
                            <field name="product_count" widget="statinfo" string="Productos"/>
                        </button>
                    </div>

                    <widget name="web_ribbon"
                            text="Archivado"
                            bg_color="text-bg-danger"
                            invisible="active"/>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"
                                   placeholder="Nombre de la etiqueta..."
                                   required="True"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Configuración">
                            <field name="operation_type" required="True"/>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                        <group string="Estadísticas">
                            <field name="product_count" string="Productos asociados"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Descripción" name="description">
                            <field name="description"
                                   placeholder="Describe el uso y propósito de esta etiqueta operativa..."
                                   nolabel="1"/>
                        </page>
                        <page string="Productos" name="products">
                            <field name="product_ids" nolabel="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="categ_id" string="Categoría"/>
                                    <field name="type" string="Tipo"/>
                                    <field name="operation_tag_count" string="Nº Etiquetas"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista Kanban de Etiquetas -->
    <record id="view_stock_operation_tag_kanban" model="ir.ui.view">
        <field name="name">stock.operation.tag.kanban</field>
        <field name="model">stock.operation.tag</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" default_group_by="operation_type">
                <field name="name"/>
                <field name="color"/>
                <field name="operation_type"/>
                <field name="product_count"/>
                <field name="description"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_color_#{record.color.raw_value} oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <t t-if="record.description.raw_value">
                                        <p class="text-muted small">
                                            <field name="description"/>
                                        </p>
                                    </t>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span class="badge text-bg-primary">
                                            <i class="fa fa-cube me-1"/>
                                            <field name="product_count"/> productos
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista Búsqueda -->
    <record id="view_stock_operation_tag_search" model="ir.ui.view">
        <field name="name">stock.operation.tag.search</field>
        <field name="model">stock.operation.tag</field>
        <field name="arch" type="xml">
            <search string="Buscar Etiquetas Operativas">
                <field name="name" string="Etiqueta"/>
                <field name="operation_type"/>
                <separator/>
                <filter name="picking" string="Picking"
                        domain="[('operation_type','=','picking')]"/>
                <filter name="storage" string="Almacenamiento"
                        domain="[('operation_type','=','storage')]"/>
                <filter name="dispatch" string="Despacho"
                        domain="[('operation_type','=','dispatch')]"/>
                <filter name="reception" string="Recepción"
                        domain="[('operation_type','=','reception')]"/>
                <filter name="quality" string="Calidad"
                        domain="[('operation_type','=','quality')]"/>
                <separator/>
                <filter name="active" string="Archivados"
                        domain="[('active','=',False)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_by_operation_type"
                            string="Tipo de Operación"
                            context="{'group_by': 'operation_type'}"/>
                    <filter name="group_by_color"
                            string="Color"
                            context="{'group_by': 'color'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción de ventana -->
    <record id="action_stock_operation_tag" model="ir.actions.act_window">
        <field name="name">Etiquetas Operativas</field>
        <field name="res_model">stock.operation.tag</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_stock_operation_tag_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primera etiqueta operativa
            </p>
            <p>
                Las etiquetas operativas te permiten clasificar productos
                para optimizar picking, almacenamiento y despacho.
            </p>
        </field>
    </record>

    <!-- Menú en Inventario → Configuración -->
    <menuitem id="menu_stock_operation_tag"
              name="Etiquetas Operativas"
              parent="stock.menu_stock_config_settings"
              action="action_stock_operation_tag"
              sequence="50"/>

</odoo>
